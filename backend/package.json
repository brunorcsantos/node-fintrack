{
  "name": "fintrack-backend",
  "version": "1.0.0",
  "description": "FinTrack API — Fastify + Prisma + PostgreSQL",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "postinstall": "prisma generate --schema=prisma/schema.prisma",
    "db:migrate": "npx prisma migrate dev --schema=prisma/schema.prisma",
    "db:migrate:prod": "npx prisma migrate deploy --schema=prisma/schema.prisma",
    "db:migrate:sqlite": "npx prisma migrate dev --schema=prisma/schema.sqlite.prisma",
    "db:migrate:sqlite:prod": "npx prisma migrate deploy --schema=prisma/schema.sqlite.prisma",
    "db:generate": "npx prisma generate --schema=prisma/schema.prisma",
    "db:generate:sqlite": "npx prisma generate --schema=prisma/schema.sqlite.prisma",
    "db:studio": "npx prisma studio --schema=prisma/schema.prisma",
    "db:studio:sqlite": "npx prisma studio --schema=prisma/schema.sqlite.prisma",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^7.6.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.2.0",
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "fastify-type-provider-zod": "^1.2.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.14.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5"
  }
}
